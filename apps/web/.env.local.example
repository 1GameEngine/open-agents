# Local secret overrides (not committed).
#   cp apps/web/.env.local.example apps/web/.env.local
#
# Load order:
# 1) .env
# 2) .env.dev or .env.prod (based on NODE_ENV)
# 3) .env.local
# 4) .env.dev.local or .env.prod.local
#
# Put secrets here.
AI_GATEWAY_API_KEY=
# GITHUB_CLIENT_SECRET=
# GITHUB_APP_PRIVATE_KEY=

# ─── 1game SSO (override if your local ports differ) ─────────────────────────
# Mock verify server (fixed user): from repo root run `bun run mock:sso`, then:
# MBBS_API_BASE_URL=http://127.0.0.1:8840/main
# Optional: MOCK_SSO_USER_ID, MOCK_SSO_USERNAME, MOCK_SSO_PORT (see scripts/mock-sso-server.ts)
# NEXT_PUBLIC_BBS_BASE_URL=http://localhost:8841
# NEXT_PUBLIC_AGENTS_SSO_BASE_URL=http://localhost:3000/api/auth/sso
