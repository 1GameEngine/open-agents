{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development bun run scripts/run-with-env.ts next dev",
    "dev:pglite": "mkdir -p ./data && npx pglite-server --db=./data/dev.db --host=127.0.0.1 --port=5433 --run \"bun run dev:pglite:child\"",
    "dev:pglite:child": "NODE_ENV=development bun run scripts/run-with-env.ts bun run db:migrate:apply && NODE_ENV=development bun run scripts/run-with-env.ts bun run bootstrap && NODE_ENV=development bun run scripts/run-with-env.ts next dev",
    "build": "NODE_ENV=production bun run scripts/run-with-env.ts bun run db:migrate:apply && NODE_ENV=production bun run scripts/run-with-env.ts next build",
    "db:migrate:apply": "bun run scripts/run-with-env.ts bun run lib/db/migrate.ts",
    "start": "NODE_ENV=production bun run scripts/run-with-env.ts next start",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:check": "bun run scripts/check-migrations.ts",
    "workflow:setup": "npx workflow-postgres-setup",
    "bootstrap": "bun run scripts/bootstrap-admin.ts",
    "seed:points-deduct": "bun run scripts/run-with-env.ts bun run scripts/seed-points-deduction-demo.ts",
    "e2e:real-ai-points": "bun run scripts/run-with-env.ts bun run scripts/e2e-real-ai-points.ts"
  },
  "dependencies": {
    "@ai-sdk/elevenlabs": "^2.0.29",
    "@ai-sdk/react": "catalog:",
    "@electric-sql/pglite": "^0.3.2",
    "@electric-sql/pglite-socket": "^0.0.7",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@open-harness/agent": "workspace:*",
    "@open-harness/sandbox": "workspace:*",
    "@open-harness/shared": "workspace:*",
    "@pierre/diffs": "^1.0.10",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@streamdown/code": "^1.0.3",
    "@workflow/world-postgres": "^4.1.1",
    "ai": "catalog:",
    "arctic": "^3.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "ioredis": "^5.9.2",
    "jose": "^6.1.3",
    "lucide-react": "^0.562.0",
    "nanoid": "^5.1.6",
    "next": "16.2.1",
    "postgres": "^3.4.8",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "streamdown": "^2.2.0",
    "swr": "^2.3.8",
    "tailwind-merge": "^3.4.0",
    "vaul": "^1.1.2",
    "workflow": "^4.2.0-beta.72",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "^0.31.8",
    "pg": "8.14.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
