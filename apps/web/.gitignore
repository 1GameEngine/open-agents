# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# PGlite local database (dev:pglite)
/data/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
# Track shared defaults and non-secret overlays for zero-config startup.
# Keep local secret overrides out of git.
.env.local
.env.*.local
!.env.local.example
!.env.dev.local.example
!.env.prod.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.devtools
