# Copy to `.env` for production or custom setups. For local one-command dev, use the
# committed `apps/web/.env` instead (see README).

# ─── Database ────────────────────────────────────────────────────────────────
# PGlite (`bun run dev:pglite`): postgres on 127.0.0.1:5433
DATABASE_URL="postgres://postgres:postgres@127.0.0.1:5433/postgres"
POSTGRES_URL="postgres://postgres:postgres@127.0.0.1:5433/postgres"
POSTGRES_POOL_MAX=1

# ─── Workflow (local file world with PGlite) ─────────────────────────────────
WORKFLOW_TARGET_WORLD="local"
WORKFLOW_LOCAL_DATA_DIR="/tmp/open-agents-workflow-local"

# Legacy / optional when using full Postgres workflow world instead of local:
# WORKFLOW_POSTGRES_URL="postgres://postgres:postgres@localhost:5432/open_agents"

# ─── AI Gateway (Vercel AI Gateway) ─────────────────────────────────────────
AI_GATEWAY_API_KEY=

# ─── Session / crypto ─────────────────────────────────────────────────────────
JWE_SECRET=
ENCRYPTION_KEY=

# ─── Browser + bootstrap (local dev) ─────────────────────────────────────────
# NEXT_PUBLIC_SELF_HOSTED_API_KEY=
# BOOTSTRAP_API_KEY=   # optional: if set and starts with oha_, used as first API key

# ─── Sandbox (local-fs) ──────────────────────────────────────────────────────
SANDBOX_ROOT_DIR="/tmp/open-agents-sandboxes"

# ─── GitHub Integration (optional) ─────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
NEXT_PUBLIC_GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# ─── Voice (optional) ────────────────────────────────────────────────────────
# ELEVENLABS_API_KEY=
