# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string for Drizzle ORM (application data)
DATABASE_URL="postgres://postgres:postgres@localhost:5432/open_agents"
# App runtime (Drizzle) — same as DATABASE_URL unless you split read replicas later
POSTGRES_URL="postgres://postgres:postgres@localhost:5432/open_agents"
# Optional: cap postgres.js pool size (use 1 with PGlite dev server — see dev:pglite)
# POSTGRES_POOL_MAX=1

# ─── Workflow (Durable Execution) ────────────────────────────────────────────
# For local PGlite (`bun run dev:pglite`), use the file-backed local world so the
# app DB connection is not contended with graphile-worker:
WORKFLOW_TARGET_WORLD="local"
WORKFLOW_LOCAL_DATA_DIR="/tmp/open-agents-workflow-local"

# PostgreSQL connection string for the workflow engine (graphile-worker).
# Can be the same database as DATABASE_URL or a separate one.
# Falls back to DATABASE_URL if not set.
WORKFLOW_POSTGRES_URL="postgres://postgres:postgres@localhost:5432/open_agents"

# Number of concurrent graphile-worker job processors (default: 10)
# WORKFLOW_POSTGRES_WORKER_CONCURRENCY=10

# ─── AI Gateway (Vercel AI Gateway) ──────────────────────────────────────────
# API key for Vercel AI Gateway. Sent as `Authorization: Bearer <key>`.
# Obtain from: https://vercel.com/dashboard/ai-gateway
AI_GATEWAY_API_KEY=

# ─── Session / crypto (required for JWE session cookies if you use OAuth flows) ─
# JWE_SECRET="$(openssl rand -base64 32 | tr '+/' '-_' | tr -d '=\n')"
# ENCRYPTION_KEY="$(openssl rand -hex 32)"

# ─── Local dev: browser API key (optional) ───────────────────────────────────
# When set, the web app patches fetch() to send `Authorization: Bearer …` for /api/*
# and sets a first-party cookie so RSC pages (e.g. /sessions/.../chats/...) authenticate.
# Must match a key from `bun run bootstrap` (printed once).
# NEXT_PUBLIC_SELF_HOSTED_API_KEY=

# ─── Authentication (API Key) ─────────────────────────────────────────────────
# No OAuth provider is required in self-hosted mode.
# Users authenticate via API keys managed through /api/auth/api-keys.
#
# To bootstrap the first admin user and generate an initial API key, run:
#   bun run scripts/bootstrap-admin.ts

# ─── GitHub Integration (optional) ───────────────────────────────────────────
# Required only if you want the agent to clone and push to GitHub repositories.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
NEXT_PUBLIC_GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# ─── Sandbox ─────────────────────────────────────────────────────────────────
# Root directory for all session sandbox directories.
# Each session gets an isolated subdirectory under this path.
# Defaults to /tmp/open-agents-sandboxes if not set.
# SANDBOX_ROOT_DIR=/var/lib/open-agents/sandboxes

# ─── Voice (optional) ────────────────────────────────────────────────────────
# Required only if you want voice transcription features.
# ELEVENLABS_API_KEY=

# ─── Development: PGlite (zero-dependency local PostgreSQL) ──────────────────
# From apps/web:
#
#   bun run dev:pglite
#
# This starts PGlite on 127.0.0.1:5433, runs migrations + bootstrap, then `next dev`.
# Set POSTGRES_URL / DATABASE_URL to:
#   postgres://postgres:postgres@127.0.0.1:5433/postgres
# and POSTGRES_POOL_MAX=1 (PGlite accepts one DB client at a time).
#
# No external PostgreSQL installation is required.
