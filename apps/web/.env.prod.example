# Copy to `apps/web/.env.prod` for production-like local runs.
#   cp apps/web/.env.prod.example apps/web/.env.prod
#
# Production note:
# - Replace all placeholder values before real deployment.
# - Do not reuse dev secrets from .env.dev.

# ─── Database (production) ────────────────────────────────────────────────────
DATABASE_URL="postgres://user:password@db-host:5432/open_agents"
POSTGRES_URL="postgres://user:password@db-host:5432/open_agents"
POSTGRES_POOL_MAX=20

# ─── Workflow (production default: postgres world) ───────────────────────────
WORKFLOW_TARGET_WORLD="postgres"
WORKFLOW_POSTGRES_URL="postgres://user:password@db-host:5432/open_agents"

# ─── Crypto (must be generated securely) ─────────────────────────────────────
JWE_SECRET="replace-with-a-secure-random-base64url-secret"
ENCRYPTION_KEY="replace-with-a-secure-random-hex-64-char-key"

# ─── AI Gateway ───────────────────────────────────────────────────────────────
AI_GATEWAY_API_KEY=

# ─── Browser auth / API bootstrap (set your own strong key) ──────────────────
NEXT_PUBLIC_SELF_HOSTED_API_KEY="replace-with-your-production-api-key"
BOOTSTRAP_API_KEY="replace-with-your-production-api-key"

# ─── Sandbox (adjust for your deployment filesystem) ─────────────────────────
SANDBOX_ROOT_DIR="/var/lib/open-agents/sandboxes"

# ─── App URL (recommended in production) ─────────────────────────────────────
APP_URL="https://your-domain.example.com"

# ─── GitHub Integration (optional) ───────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
NEXT_PUBLIC_GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# ─── Voice (optional) ────────────────────────────────────────────────────────
# ELEVENLABS_API_KEY=
