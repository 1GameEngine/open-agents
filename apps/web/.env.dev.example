# Copy to `apps/web/.env.dev` for local development overrides.
#   cp apps/web/.env.dev.example apps/web/.env.dev
#
# Load order at startup:
# 1) `.env` (base/default values)
# 2) `.env.dev` (override only differences for development)
#
# Keep this file small. Put shared defaults in `.env`, and only put
# development-specific differences here.

# Example: override database only for dev if needed.
# DATABASE_URL="postgres://postgres:postgres@127.0.0.1:5433/postgres"
# POSTGRES_URL="postgres://postgres:postgres@127.0.0.1:5433/postgres"

# Example: isolate workflow local storage path per developer machine.
# WORKFLOW_LOCAL_DATA_DIR="/tmp/open-agents-workflow-local-dev"
