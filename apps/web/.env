# Base env committed to git for zero-config startup.
# Put only non-secret shared defaults here.
#
# Vercel AI Gateway: https://vercel.com/dashboard/ai-gateway

# ─── Database (PGlite: `bun run dev:pglite` listens on 5433) ─────────────────
DATABASE_URL="postgres://postgres:postgres@127.0.0.1:5433/postgres"
POSTGRES_URL="postgres://postgres:postgres@127.0.0.1:5433/postgres"
POSTGRES_POOL_MAX=1

# ─── Workflow (local file world — does not share PGlite connection) ─────────
WORKFLOW_TARGET_WORLD="local"
WORKFLOW_LOCAL_DATA_DIR="/home/open-agents/workflow-local"

# ─── Crypto (dev defaults — rotate for anything beyond local throwaway) ────
JWE_SECRET="2Lp_JtGLAUQQ78is4SJh2PEn0UdlAGSpoBlGKPl4J1A"
ENCRYPTION_KEY="144f59373047778583331cbf6c62c5b7796c335f2f3b848a327ad709bae96ab4"

# ─── AI Gateway (set in .env.local or .env.dev.local, do not commit secrets) ─
AI_GATEWAY_API_KEY=

# ─── Browser auth (must match BOOTSTRAP_API_KEY on first bootstrap) ─────────
NEXT_PUBLIC_SELF_HOSTED_API_KEY="oha_devlocal_openharness_default_key_change_me"

# ─── Bootstrap: deterministic initial API key (first DB run only) ────────────
BOOTSTRAP_API_KEY="oha_devlocal_openharness_default_key_change_me"

# ─── Sandbox (local-fs session roots) ───────────────────────────────────────
SANDBOX_ROOT_DIR="/home/open-agents/sandboxes"

# ─── GitHub Integration (optional) ───────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
NEXT_PUBLIC_GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# ─── Voice (optional) ────────────────────────────────────────────────────────
# ELEVENLABS_API_KEY=
